# Copy to .env and set as needed. Do not commit .env (add to .gitignore).

# Hugging Face token for gated models (e.g. some T5/VAE or private repos).
# Used by transformers/diffusers when loading from HF.
# HF_TOKEN=your_token_here

# Optional: limit visible GPUs (e.g. for multi-GPU or WSL).
# CUDA_VISIBLE_DEVICES=0
